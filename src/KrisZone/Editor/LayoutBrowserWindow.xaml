<Window x:Class="KrisZone.Editor.LayoutBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="K-FancyZones 편집기" Width="1100" Height="720"
        MinWidth="700" MinHeight="500"
        Background="White" WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        FontFamily="Segoe UI">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 모니터 탭 -->
        <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled" Padding="24,16,24,16">
            <StackPanel x:Name="MonitorPanel" Orientation="Horizontal"/>
        </ScrollViewer>

        <Rectangle Grid.Row="1" Fill="#E5E7EB"/>

        <!-- 레이아웃 콘텐츠 -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="24,20,24,0">
            <StackPanel x:Name="ContentPanel"/>
        </ScrollViewer>

        <Rectangle Grid.Row="3" Fill="#E5E7EB"/>

        <!-- 하단 바 -->
        <Border Grid.Row="4" Background="White" Padding="24,12">
            <Button x:Name="NewLayoutButton" HorizontalAlignment="Right" Click="NewLayout_Click" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#3B82F6" CornerRadius="6" Padding="16,9">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="＋" FontSize="14" FontWeight="Bold" Foreground="White"
                                           Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="새 레이아웃 만들기" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2563EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Border>
    </Grid>
</Window>

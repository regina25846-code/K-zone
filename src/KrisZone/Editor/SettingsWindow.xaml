<Window x:Class="KrisZone.Editor.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KrisZone 설정" Width="340" Height="560"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E" Foreground="White"
        ResizeMode="NoResize">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20,20,20,20">
            <TextBlock Text="존 색상" FontSize="12" Foreground="#9CA3AF" Margin="0,0,0,6"/>
            <Grid Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="34"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="ZoneColorBox" Grid.Column="0" Background="#2A2A3E" Foreground="White"
                         BorderBrush="#3A3A5E" Padding="8,6" FontSize="13"
                         TextChanged="ZoneColor_Changed"/>
                <Border x:Name="ZoneColorPreview" Grid.Column="1" Margin="6,0,0,0" CornerRadius="4"
                        BorderBrush="#3A3A5E" BorderThickness="1"/>
                <Button x:Name="ZoneColorPickBtn" Grid.Column="2" Margin="4,0,0,0" ToolTip="스포이드"
                        Background="#2A2A3E" Foreground="White" BorderBrush="#3A3A5E"
                        Click="EyeDropper_Click" Tag="ZoneColorBox">
                    <Viewbox Width="15" Height="15">
                        <Canvas Width="24" Height="24">
                            <Path Data="M13.5,6.5 L17.5,10.5" Stroke="White" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            <Path Data="M17,3 L21,7 L18.5,9.5 L14.5,5.5 Z" Stroke="White" StrokeThickness="1.8" StrokeLineJoin="Round"/>
                            <Path Data="M14.5,5.5 L5,15 L5,19 L9,19 L18.5,9.5" Stroke="White" StrokeThickness="1.8" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            <Ellipse Canvas.Left="6.4" Canvas.Top="15.4" Width="2.2" Height="2.2" Fill="White"/>
                        </Canvas>
                    </Viewbox>
                </Button>
            </Grid>

            <TextBlock Text="하이라이트 색상" FontSize="12" Foreground="#9CA3AF" Margin="0,14,0,6"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="34"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="HighlightColorBox" Grid.Column="0" Background="#2A2A3E" Foreground="White"
                         BorderBrush="#3A3A5E" Padding="8,6" FontSize="13"
                         TextChanged="ZoneColor_Changed"/>
                <Border x:Name="HighlightColorPreview" Grid.Column="1" Margin="6,0,0,0" CornerRadius="4"
                        BorderBrush="#3A3A5E" BorderThickness="1"/>
                <Button x:Name="HighlightColorPickBtn" Grid.Column="2" Margin="4,0,0,0" ToolTip="스포이드"
                        Background="#2A2A3E" Foreground="White" BorderBrush="#3A3A5E"
                        Click="EyeDropper_Click" Tag="HighlightColorBox">
                    <Viewbox Width="15" Height="15">
                        <Canvas Width="24" Height="24">
                            <Path Data="M13.5,6.5 L17.5,10.5" Stroke="White" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            <Path Data="M17,3 L21,7 L18.5,9.5 L14.5,5.5 Z" Stroke="White" StrokeThickness="1.8" StrokeLineJoin="Round"/>
                            <Path Data="M14.5,5.5 L5,15 L5,19 L9,19 L18.5,9.5" Stroke="White" StrokeThickness="1.8" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            <Ellipse Canvas.Left="6.4" Canvas.Top="15.4" Width="2.2" Height="2.2" Fill="White"/>
                        </Canvas>
                    </Viewbox>
                </Button>
            </Grid>

            <TextBlock Text="불투명도 (0~100)" FontSize="12" Foreground="#9CA3AF" Margin="0,14,0,6"/>
            <Slider x:Name="OpacitySlider" Minimum="0" Maximum="100" Value="50"
                    Foreground="#3B82F6" ValueChanged="Opacity_Changed"/>
            <TextBlock x:Name="OpacityLabel" Text="50%" FontSize="11" Foreground="#6B7280" Margin="0,2,0,0"/>

            <Separator Background="#2A2A4E" Margin="0,18,0,18"/>

            <TextBlock Text="동작 설정" FontSize="13" FontWeight="SemiBold" Foreground="#9CA3AF" Margin="0,0,0,12"/>

            <CheckBox x:Name="ShiftDragCheck" Content="Shift+드래그로 존 활성화" Foreground="White"
                      FontSize="13" Margin="0,0,0,10" Checked="Settings_Changed" Unchecked="Settings_Changed"/>
            <CheckBox x:Name="TransparentCheck" Content="드래그 중 창 투명화" Foreground="White"
                      FontSize="13" Margin="0,0,0,10" Checked="Settings_Changed" Unchecked="Settings_Changed"/>
            <CheckBox x:Name="ShowNumberCheck" Content="존 번호 표시" Foreground="White"
                      FontSize="13" Margin="0,0,0,10" Checked="Settings_Changed" Unchecked="Settings_Changed"/>
            <CheckBox x:Name="OverrideSnapCheck" Content="Win+방향키 오버라이드" Foreground="White"
                      FontSize="13" Margin="0,0,0,10" Checked="Settings_Changed" Unchecked="Settings_Changed"/>
            <CheckBox x:Name="AlwaysOnTopCheck" Content="Win+Ctrl+X 항상 위 고정/해제" Foreground="White"
                      FontSize="13" Margin="0,0,0,10" Checked="Settings_Changed" Unchecked="Settings_Changed"/>

            <TextBlock Text="항상 위 테두리 색상" FontSize="12" Foreground="#9CA3AF" Margin="0,4,0,6"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="34"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="AlwaysOnTopColorBox" Grid.Column="0" Background="#2A2A3E" Foreground="White"
                         BorderBrush="#3A3A5E" Padding="8,6" FontSize="13"
                         TextChanged="ZoneColor_Changed"/>
                <Border x:Name="AlwaysOnTopColorPreview" Grid.Column="1" Margin="6,0,0,0" CornerRadius="4"
                        BorderBrush="#3A3A5E" BorderThickness="1"/>
                <Button x:Name="AlwaysOnTopColorPickBtn" Grid.Column="2" Margin="4,0,0,0" ToolTip="스포이드"
                        Background="#2A2A3E" Foreground="White" BorderBrush="#3A3A5E"
                        Click="EyeDropper_Click" Tag="AlwaysOnTopColorBox">
                    <Viewbox Width="15" Height="15">
                        <Canvas Width="24" Height="24">
                            <Path Data="M13.5,6.5 L17.5,10.5" Stroke="White" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            <Path Data="M17,3 L21,7 L18.5,9.5 L14.5,5.5 Z" Stroke="White" StrokeThickness="1.8" StrokeLineJoin="Round"/>
                            <Path Data="M14.5,5.5 L5,15 L5,19 L9,19 L18.5,9.5" Stroke="White" StrokeThickness="1.8" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            <Ellipse Canvas.Left="6.4" Canvas.Top="15.4" Width="2.2" Height="2.2" Fill="White"/>
                        </Canvas>
                    </Viewbox>
                </Button>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Window>

<Window x:Class="KrisZone.Editor.MonitorOverlayEditor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#B2000010"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual">

    <Grid>
        <!-- Zone Preview Canvas -->
        <Canvas x:Name="Preview" Background="Transparent"/>

        <!-- Resizer Adorner Layer -->
        <Canvas x:Name="AdornerLayer" Background="Transparent" IsHitTestVisible="True"/>

        <!-- Merge selection panel -->
        <Canvas x:Name="MergePanel" Background="Transparent" Visibility="Collapsed">
            <StackPanel x:Name="MergeButtons" Orientation="Horizontal" Background="#DD111122">
                <StackPanel.Resources>
                    <Style TargetType="Button">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="14,7"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </StackPanel.Resources>
                <Button Content="합치기" Background="#3B82F6" Click="MergeClick" Margin="0,0,4,0"/>
                <Button Content="취소" Background="#6B7280" Click="MergeCancelClick"/>
            </StackPanel>
        </Canvas>

        <!-- 파워토이즈 방식 인트로 팝업 (저장 전까지 유지) -->
        <Border x:Name="IntroPanel"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="#F0111827" CornerRadius="12"
                Padding="28,24" MinWidth="420" MaxWidth="500">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="30" ShadowDepth="0" Opacity="0.6"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock FontSize="15" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,16"
                           Text="KrisZone 레이아웃 편집기"/>

                <!-- 분할 안내 -->
                <TextBlock FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8">
                    <Run FontWeight="SemiBold" Foreground="White" Text="분할: "/>
                    <Run Foreground="#9CA3AF" Text="존을 클릭하면 분할됩니다. Shift를 누른 채 클릭하면 방향이 바뀝니다."/>
                </TextBlock>

                <!-- 합치기 안내 -->
                <TextBlock FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8">
                    <Run FontWeight="SemiBold" Foreground="White" Text="합치기: "/>
                    <Run Foreground="#9CA3AF" Text="존을 가로질러 드래그하면 여러 존을 선택해 합칠 수 있습니다."/>
                </TextBlock>

                <!-- 키보드 단축키 -->
                <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,6"
                           Text="키보드 단축키:"/>
                <TextBlock FontSize="12" Foreground="#9CA3AF" TextWrapping="Wrap" LineHeight="20">
                    <Run Text="• S: 포커스된 존 절반 분할  |  Shift+S: 수직 절반 분할"/>
                    <LineBreak/>
                    <Run Text="• Delete: 포커스된 구분선 삭제 (인접 존 합치기)"/>
                    <LineBreak/>
                    <Run Text="• 방향키: 포커스된 구분선 이동"/>
                    <LineBreak/>
                    <Run Text="• Ctrl+Z: 되돌리기  |  Esc: 닫기"/>
                </TextBlock>

                <!-- 저장/취소 버튼 -->
                <Grid Margin="0,24,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="저장" Click="IntroSave_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="#3B82F6" CornerRadius="7" Padding="0,10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      TextElement.Foreground="White" TextElement.FontSize="13" TextElement.FontWeight="SemiBold"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#2563EB"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Grid.Column="2" Content="취소" Click="IntroCancel_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="#374151" CornerRadius="7" Padding="0,10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      TextElement.Foreground="White" TextElement.FontSize="13"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#4B5563"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Top HUD Bar -->
        <Border VerticalAlignment="Top" HorizontalAlignment="Stretch"
                Background="#E6111122" CornerRadius="0,0,10,10" Padding="14,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" x:Name="MonitorLabel"
                           Foreground="#9CA3AF" FontSize="13" VerticalAlignment="Center"/>

                <ComboBox Grid.Column="2" x:Name="LayoutCombo"
                          Width="160" Background="#2A2A3E" Foreground="White"
                          BorderBrush="#3A3A5E" FontSize="13"
                          SelectionChanged="LayoutCombo_SelectionChanged">
                    <ComboBox.ItemContainerStyle>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Foreground" Value="#111827"/>
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Padding" Value="8,5"/>
                            <Style.Triggers>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter Property="Background" Value="#DBEAFE"/>
                                    <Setter Property="Foreground" Value="#1E40AF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ComboBox.ItemContainerStyle>
                </ComboBox>

                <TextBox Grid.Column="4" x:Name="LayoutNameBox"
                         Background="#2A2A3E" Foreground="White"
                         BorderBrush="#3A3A5E" Padding="8,5" FontSize="13"
                         TextChanged="LayoutNameBox_TextChanged"/>

                <Button Grid.Column="6" Content="＋ 새 레이아웃"
                        Click="AddLayout_Click"
                        Foreground="White" Background="#3B82F6" BorderThickness="0"
                        Padding="10,5" FontSize="12" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Grid.Column="8" Content="✕"
                        Click="Close_Click"
                        Foreground="White" Background="#EF4444" BorderThickness="0"
                        Width="30" Height="30" FontSize="13" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="15" Padding="0">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#DC2626"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>

<Window x:Class="KrisZone.Editor.MonitorOverlayEditor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#B2000010"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual">

    <Grid>
        <!-- Zone Preview Canvas -->
        <Canvas x:Name="Preview" Background="Transparent"/>

        <!-- Resizer (divider line) Adorner Layer -->
        <Canvas x:Name="AdornerLayer" Background="Transparent" IsHitTestVisible="True"/>

        <!-- Merge selection panel -->
        <Canvas x:Name="MergePanel" Background="Transparent" Visibility="Collapsed">
            <StackPanel x:Name="MergeButtons" Orientation="Horizontal"
                        Background="#DD111122" HorizontalAlignment="Left">
                <StackPanel.Resources>
                    <Style TargetType="Button">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="14,7"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </StackPanel.Resources>
                <Button Content="합치기" Background="#3B82F6" Click="MergeClick" Margin="0,0,4,0"/>
                <Button Content="취소" Background="#6B7280" Click="MergeCancelClick"/>
            </StackPanel>
        </Canvas>

        <!-- Top HUD Bar -->
        <Border VerticalAlignment="Top" HorizontalAlignment="Stretch"
                Background="#E6111122" CornerRadius="0,0,10,10" Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" x:Name="MonitorLabel"
                           Foreground="#9CA3AF" FontSize="13" VerticalAlignment="Center"/>

                <ComboBox Grid.Column="2" x:Name="LayoutCombo"
                          Width="160" Background="#2A2A3E" Foreground="White"
                          BorderBrush="#3A3A5E" FontSize="13"
                          SelectionChanged="LayoutCombo_SelectionChanged">
                    <ComboBox.ItemContainerStyle>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Foreground" Value="#111827"/>
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Padding" Value="8,5"/>
                            <Style.Triggers>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter Property="Background" Value="#DBEAFE"/>
                                    <Setter Property="Foreground" Value="#1E40AF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ComboBox.ItemContainerStyle>
                </ComboBox>

                <TextBox Grid.Column="4" x:Name="LayoutNameBox"
                         Background="#2A2A3E" Foreground="White"
                         BorderBrush="#3A3A5E" Padding="8,5" FontSize="13"
                         TextChanged="LayoutNameBox_TextChanged"/>

                <Button Grid.Column="6" Content="＋ 새 레이아웃"
                        Click="AddLayout_Click"
                        Foreground="White" Background="#3B82F6" BorderThickness="0"
                        Padding="10,5" FontSize="12" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <TextBlock Grid.Column="8"
                           Text="클릭: 분할  |  Shift+클릭: 가로분할  |  드래그: 존 선택 합치기  |  Ctrl+Z: 되돌리기  |  Esc: 닫기"
                           Foreground="#6B7280" FontSize="11" VerticalAlignment="Center"/>

                <Button Grid.Column="10" Content="이 모니터에 적용"
                        Click="Apply_Click"
                        Foreground="White" Background="#10B981" BorderThickness="0"
                        Padding="12,6" FontSize="13" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#059669"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Grid.Column="12" Content="✕"
                        Click="Close_Click"
                        Foreground="White" Background="#EF4444" BorderThickness="0"
                        Width="32" Height="32" FontSize="14" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="16" Padding="0">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#DC2626"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>

<Window x:Class="KrisZone.Editor.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KrisZone 편집기" Width="1100" Height="720"
        MinWidth="800" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E" Foreground="White">
    <Window.Resources>
        <Style TargetType="Button" x:Key="BtnPrimary">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2563EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="BtnDanger">
            <Setter Property="Background" Value="#EF4444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ListBoxItem" x:Key="LayoutItem">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Margin="0,2" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3B82F6"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2A3E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel: Layout List -->
        <Grid Grid.Column="0" Background="#16162A" Margin="0,0,1,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="12,14,12,10">
                <TextBlock Text="레이아웃 목록" FontSize="13" FontWeight="SemiBold" Foreground="#9CA3AF" Margin="0,0,0,10"/>
                <ComboBox x:Name="MonitorCombo" Margin="0,0,0,0" Background="#2A2A3E" Foreground="White"
                          BorderBrush="#3A3A5E" SelectionChanged="MonitorCombo_SelectionChanged"/>
            </StackPanel>

            <ListBox x:Name="LayoutList" Grid.Row="1" Background="Transparent" BorderThickness="0"
                     Margin="8,0,8,8" ItemContainerStyle="{StaticResource LayoutItem}"
                     SelectionChanged="LayoutList_SelectionChanged"/>

            <StackPanel Grid.Row="2" Margin="12,8,12,12" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="＋ 새 레이아웃" Style="{StaticResource BtnPrimary}" Click="AddLayout_Click" Margin="0,0,6,0"/>
                <Button Content="삭제" Style="{StaticResource BtnDanger}" Click="DeleteLayout_Click"/>
            </StackPanel>
        </Grid>

        <!-- Center: Zone Canvas Editor -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="16,10" VerticalAlignment="Center">
                <TextBox x:Name="LayoutNameBox" Background="#2A2A3E" Foreground="White"
                         BorderBrush="#3A3A5E" Padding="8,5" FontSize="14" Width="200"
                         TextChanged="LayoutNameBox_TextChanged"/>
                <TextBlock Text="드래그로 존 생성 · 존 우클릭으로 삭제 · Ctrl+Z로 되돌리기"
                           Foreground="#6B7280" FontSize="12" VerticalAlignment="Center" Margin="16,0,0,0"/>
            </StackPanel>

            <!-- Monitor Preview Canvas -->
            <Border Grid.Row="1" Margin="16,0,16,16" Background="#111122" CornerRadius="8"
                    BorderBrush="#2A2A4E" BorderThickness="1" ClipToBounds="True">
                <Canvas x:Name="ZoneCanvas" Background="Transparent"
                        MouseLeftButtonDown="Canvas_MouseDown"
                        MouseMove="Canvas_MouseMove"
                        MouseLeftButtonUp="Canvas_MouseUp"
                        MouseRightButtonDown="Canvas_RightClick"/>
            </Border>
        </Grid>

        <!-- Right Panel: Settings -->
        <Grid Grid.Column="2" Background="#16162A" Margin="1,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="14,14,14,14">
                    <TextBlock Text="모니터에 적용" FontSize="13" FontWeight="SemiBold" Foreground="#9CA3AF" Margin="0,0,0,8"/>
                    <Button Content="이 모니터에 적용" Style="{StaticResource BtnPrimary}" Click="Apply_Click" HorizontalAlignment="Stretch"/>

                    <Separator Background="#2A2A4E" Margin="0,16,0,16"/>

                    <TextBlock Text="존 색상" FontSize="12" Foreground="#9CA3AF" Margin="0,0,0,6"/>
                    <TextBox x:Name="ZoneColorBox" Background="#2A2A3E" Foreground="White"
                             BorderBrush="#3A3A5E" Padding="6,4" FontSize="12"
                             TextChanged="ZoneColor_Changed"/>

                    <TextBlock Text="하이라이트 색상" FontSize="12" Foreground="#9CA3AF" Margin="0,10,0,6"/>
                    <TextBox x:Name="HighlightColorBox" Background="#2A2A3E" Foreground="White"
                             BorderBrush="#3A3A5E" Padding="6,4" FontSize="12"
                             TextChanged="ZoneColor_Changed"/>

                    <TextBlock Text="불투명도 (0~100)" FontSize="12" Foreground="#9CA3AF" Margin="0,10,0,6"/>
                    <Slider x:Name="OpacitySlider" Minimum="0" Maximum="100" Value="50"
                            Foreground="#3B82F6" ValueChanged="Opacity_Changed"/>
                    <TextBlock x:Name="OpacityLabel" Text="50%" FontSize="11" Foreground="#6B7280"/>

                    <Separator Background="#2A2A4E" Margin="0,16,0,16"/>

                    <TextBlock Text="동작 설정" FontSize="13" FontWeight="SemiBold" Foreground="#9CA3AF" Margin="0,0,0,10"/>

                    <CheckBox x:Name="ShiftDragCheck" Content="Shift+드래그로 존 활성화" Foreground="White"
                              FontSize="12" Margin="0,0,0,8" Checked="Settings_Changed" Unchecked="Settings_Changed"/>
                    <CheckBox x:Name="TransparentCheck" Content="드래그 중 창 투명화" Foreground="White"
                              FontSize="12" Margin="0,0,0,8" Checked="Settings_Changed" Unchecked="Settings_Changed"/>
                    <CheckBox x:Name="ShowNumberCheck" Content="존 번호 표시" Foreground="White"
                              FontSize="12" Margin="0,0,0,8" Checked="Settings_Changed" Unchecked="Settings_Changed"/>
                    <CheckBox x:Name="OverrideSnapCheck" Content="Win+방향키 오버라이드" Foreground="White"
                              FontSize="12" Margin="0,0,0,8" Checked="Settings_Changed" Unchecked="Settings_Changed"/>
                    <CheckBox x:Name="AppLastZoneCheck" Content="앱별 마지막 존 기억" Foreground="White"
                              FontSize="12" Margin="0,0,0,8" Checked="Settings_Changed" Unchecked="Settings_Changed"/>

                    <Separator Background="#2A2A4E" Margin="0,16,0,16"/>

                    <TextBlock Text="제외 앱 (줄바꿈으로 구분)" FontSize="12" Foreground="#9CA3AF" Margin="0,0,0,6"/>
                    <TextBox x:Name="ExcludedAppsBox" Background="#2A2A3E" Foreground="White"
                             BorderBrush="#3A3A5E" Padding="6,4" FontSize="12"
                             AcceptsReturn="True" Height="80" VerticalScrollBarVisibility="Auto"
                             TextChanged="ExcludedApps_Changed"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
